{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboard"
    ],
    "pinDigests": true,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "flux": {
        "managerFilePatterns": [
            "/clusters/.+\\.yaml$/",
            "/infrastructure/.+\\.yaml$/",
            "/apps/.+\\.yaml$/",
            "/repositories/.+\\.yaml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/apps/.+\\.yaml$/",
            "/infrastructure/.+\\.yaml$/"
        ]
    },
    "helm-values": {
        "managerFilePatterns": [
            "/apps/.+\\.yaml$/",
            "/infrastructure/.+\\.yaml$/"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Traefik plugin versions",
            "managerFilePatterns": [
                "/infrastructure/traefik/helmrelease\\.yaml$/"
            ],
            "matchStrings": [
                "moduleName:\\s*\"github\\.com/(?<depName>[^\"]+)\"\\s*version:\\s*\"v(?<currentValue>[^\"]+)\""
            ],
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "Kustomize version in CI",
            "managerFilePatterns": [
                "/.github/workflows/.+\\.yaml$/"
            ],
            "matchStrings": [
                "KUSTOMIZE_VERSION:\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "kubernetes-sigs/kustomize",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^kustomize/v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "Kubeconform version in CI",
            "managerFilePatterns": [
                "/.github/workflows/.+\\.yaml$/"
            ],
            "matchStrings": [
                "KUBECONFORM_VERSION:\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "yannh/kubeconform",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "Kubernetes schema version used by kubeconform in CI",
            "managerFilePatterns": [
                "/.github/workflows/.+\\.yaml$/"
            ],
            "matchStrings": [
                "KUBERNETES_VERSION:\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "kubernetes/kubernetes",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "Flux CLI version in CI",
            "managerFilePatterns": [
                "/.github/workflows/.+\\.yaml$/"
            ],
            "matchStrings": [
                "FLUX_VERSION:\\s*\"(?<currentValue>[^\"]+)\""
            ],
            "depNameTemplate": "fluxcd/flux2",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "yamllint version in CI",
            "managerFilePatterns": [
                "/.github/workflows/.+\\.yaml$/"
            ],
            "matchStrings": [
                "yamllint==(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "yamllint",
            "datasourceTemplate": "pypi"
        },
        {
            "customType": "regex",
            "description": "Talos version in talconfig",
            "managerFilePatterns": [
                "/talos/talconfig\\.yaml$/"
            ],
            "matchStrings": [
                "talosVersion:\\s*v(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "siderolabs/talos",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        },
        {
            "customType": "regex",
            "description": "Kubernetes version in talconfig",
            "managerFilePatterns": [
                "/talos/talconfig\\.yaml$/"
            ],
            "matchStrings": [
                "kubernetesVersion:\\s*v(?<currentValue>[^\\s]+)"
            ],
            "depNameTemplate": "kubernetes/kubernetes",
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        }
    ],
    "packageRules": [
        {
            "description": "Auto-merge digest pins and lockfile/pin maintenance only - no unattended version bumps",
            "matchUpdateTypes": [
                "pin",
                "digest",
                "pinDigest",
                "lockFileMaintenance"
            ],
            "automerge": true,
            "platformAutomerge": true
        },
        {
            "description": "Auto-merge minor and patch version bumps of charts and images once CI passes",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true,
            "platformAutomerge": true
        },
        {
            "description": "Talos and Kubernetes upgrades require manual steps - PR only, no auto-merge",
            "matchFileNames": [
                "talos/**"
            ],
            "automerge": false
        },
        {
            "description": "pocket-id: the v2.9.0 tag has ambiguous digests - one build (a2a38a9) is an app downgrade that crash-loops against the migrated DB, the other (9faea0c) owns the current schema. Pin the digest manually; do not let Renovate flap it. Version bumps (e.g. v2.10.0) are still allowed.",
            "matchPackageNames": [
                "ghcr.io/pocket-id/pocket-id"
            ],
            "matchUpdateTypes": [
                "digest",
                "pinDigest"
            ],
            "enabled": false
        }
    ]
}