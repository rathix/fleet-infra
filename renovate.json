{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboard"
    ],
    "pinDigests": false,
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "flux": {
        "managerFilePatterns": [
            "/clusters/.+\\.yaml$/",
            "/infrastructure/.+\\.yaml$/",
            "/apps/.+\\.yaml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/apps/.+\\.yaml$/",
            "/infrastructure/.+\\.yaml$/"
        ]
    },
    "helm-values": {
        "managerFilePatterns": [
            "/apps/.+/values.yaml$/",
            "/infrastructure/.+/values.yaml$/"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "description": "Traefik plugin versions",
            "fileMatch": ["infrastructure/traefik/helmrelease\\.yaml$"],
            "matchStrings": [
                "moduleName:\\s*\"github\\.com/(?<depName>[^\"]+)\"\\s*version:\\s*\"v(?<currentValue>[^\"]+)\""
            ],
            "datasourceTemplate": "github-releases",
            "extractVersionTemplate": "^v(?<version>.+)$"
        }
    ],
    "packageRules": [
        {
            "description": "Disable digest pinning for all container images and helm charts",
            "matchDatasources": [
                "docker",
                "helm"
            ],
            "pinDigests": false
        },
        {
            "description": "Auto-merge all minor and patch updates",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true,
            "platformAutomerge": true
        },
        {
            "description": "Group infrastructure controller updates",
            "matchFileNames": ["infrastructure/**"],
            "groupName": "infrastructure"
        },
        {
            "description": "Group application updates",
            "matchFileNames": ["apps/**"],
            "groupName": "applications"
        }
    ]
}
